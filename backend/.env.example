# LLM Provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (GPT-4o) - optional
OPENAI_API_KEY=your_openai_api_key_here

# Weather API (OpenWeatherMap free tier)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Google Custom Search (product images)
# API key: console.cloud.google.com → Enable "Custom Search API"
# CX: cse.google.com → New search engine → Search entire web → Copy ID
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CX=your_google_cx_here

# CORS - frontend URL
FRONTEND_URL=http://localhost:3000

# Save uploaded face-scan images to disk for review (debug). "0" disables.
SAVE_SCANS=1
# Where to store them (relative to backend/). Default: scans
SCANS_DIR=scans
# If set, the /api/scans* viewing endpoints require ?token=THIS_VALUE
ADMIN_TOKEN=
